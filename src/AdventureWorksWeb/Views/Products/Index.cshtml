@model IEnumerable<AdventureWorksWeb.Models.Product>
@{
    ViewData["Title"] = "Products";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Products <span class="badge bg-secondary fs-6">@ViewBag.TotalCount</span></h1>
</div>

<form method="get" class="mb-4">
    <div class="input-group" style="max-width: 480px;">
        <input type="text" name="search" value="@ViewBag.Search"
               class="form-control" placeholder="Search by name or product number..." />
        <button type="submit" class="btn btn-outline-secondary">Search</button>
        @if (!string.IsNullOrEmpty(ViewBag.Search as string))
        {
            <a asp-action="Index" class="btn btn-outline-danger">Clear</a>
        }
    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Product #</th>
                <th>Category</th>
                <th>Color</th>
                <th class="text-end">List Price</th>
                <th>Available</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in Model)
            {
                <tr>
                    <td>@product.Name</td>
                    <td><code>@product.ProductNumber</code></td>
                    <td>@(product.Category?.Name ?? "—")</td>
                    <td>@(product.Color ?? "—")</td>
                    <td class="text-end">@product.ListPrice.ToString("C")</td>
                    <td>
                        @if (product.SellEndDate == null && product.DiscontinuedDate == null)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Discontinued</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if ((int)ViewBag.TotalPages > 1)
{
    <nav>
        <ul class="pagination">
            @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == (int)ViewBag.Page ? "active" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@i"
                       asp-route-search="@ViewBag.Search">@i</a>
                </li>
            }
        </ul>
    </nav>
}
