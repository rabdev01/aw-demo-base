@{
    ViewData["Title"] = "Dashboard";
}

<div class="row mb-4">
    <div class="col">
        <h1 class="display-6 fw-bold">AdventureWorks Demo</h1>
        <p class="lead text-muted">SQL Server 2022 (ARM64) + ASP.NET Core 9 devcontainer</p>
    </div>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="card h-100 border-primary shadow-sm">
            <div class="card-body text-center py-4">
                <h5 class="card-title text-primary">Products</h5>
                <p class="display-5 fw-bold">@ViewBag.ProductCount</p>
                <a asp-controller="Products" asp-action="Index" class="btn btn-primary">Browse Products</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-success shadow-sm">
            <div class="card-body text-center py-4">
                <h5 class="card-title text-success">Customers</h5>
                <p class="display-5 fw-bold">@ViewBag.CustomerCount</p>
                <a asp-controller="Customers" asp-action="Index" class="btn btn-success">Browse Customers</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-info shadow-sm">
            <div class="card-body text-center py-4">
                <h5 class="card-title text-info">Categories</h5>
                <p class="display-5 fw-bold">@ViewBag.CategoryCount</p>
            </div>
        </div>
    </div>
</div>
